APP_NAME=Nura
APP_ENV=development

SECRET_KEY=your-long-random-secret

JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

REFRESH_TOKEN_EXPIRE_DAYS=7

FRONTEND_URL=http://localhost:3000

API_V1_PREFIX=/api/v1

LOG_LEVEL=INFO

# MongoDB
MONGODB_URL=
MONGODB_DATABASE=nura

# Qdrant
QDRANT_URL=
QDRANT_API_KEY=

# Groq
GROQ_API_KEY=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# SMTP
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_BUCKET=medical-files

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# CORS
BACKEND_CORS_ORIGINS=http://localhost:3000

# AI
DEFAULT_LLM=llama-3.3-70b-versatile
EMBEDDING_MODEL=bge-small-en-v1.5

# Upload Limits
MAX_FILE_SIZE_MB=20